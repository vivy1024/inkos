{
  "identifier": "default",
  "description": "Default capabilities for InkOS desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:scope-home-recursive",
    "deep-link:default"
  ]
}
